# PostgreSQL connection string (без пробела после password=)
DATABASE_URL=host=localhost user=postgres password=postgres dbname=inventory_db port=5432 sslmode=disable

# Сид создаёт в БД пользователей admin/admin123 и user/user123 (реальный логин через API).
# Если таблица users уже не пустая, сид по умолчанию не трогает пароли.
# Только для локального стенда: принудительно создать/обновить этих двоих:
# INVENTORY_FORCE_SEED=1

# JWT secret (в production — длинная случайная строка)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Срок жизни JWT в часах (1–8760)
JWT_EXPIRE_HOURS=24

# Режим Gin: debug | release | test
GIN_MODE=debug

# Порт HTTP
PORT=8080

# Разрешённые origin для CORS (через запятую). Пусто = localhost/127.0.0.1 на 5173–5175 и 4173 (Vite/preview).
# Если фронт на другом origin — перечислите здесь, иначе браузер заблокирует ответ (в UI похоже на «Network Error»).
# CORS_ORIGINS=http://localhost:5173,http://192.168.1.5:5173
